    reducer: ee.Reducer.sum(),
    geometry: geom,
    scale: STAT_SCALE,
    bestEffort: true,
    tileScale: 16,
    maxPixels: 1e13
  }).get('area');

  var lat = getLakeCentroidLat(name);
  var iceRisk = getIceRiskByLat(lat);
  var winterMonthList = getWinterMonthListByLat(lat);

  ee.Dictionary({
    lake: name,
    JRC90_area_km2: jrcArea,
    centroid_lat: lat,
    iceRisk: iceRisk,
    winter_months: winterMonthList,
    adjacency: false
  }).evaluate(function (d, err) {
    if (err || !d) {
      print('❌ 水体面积检查失败：', err);
