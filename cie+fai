// ====================== 4. 基础函数 ======================
function getStrictJRCMask() {
  return JRC.select('occurrence').gte(WATER_OCC_THR);
}

// 无 adjacency，只使用 JRC90
function getPhysMask() {
  return getStrictJRCMask();
}

function getLakeFeature(name) {
  return lakes.filter(ee.Filter.eq(lakeNameField, name)).first();
}

function getLakeGeomForMap(name) {
  return ee.Geometry(ee.Feature(getLakeFeature(name)).geometry());
}

function getLakeGeomForStats(name) {
  return getLakeGeomForMap(name).simplify(GEOM_SIMPLIFY);
}

function getLakeCentroidLat(name) {
  var geom = getLakeGeomForMap(name);
  return ee.Number(geom.centroid(1000).coordinates().get(1));
}

function getWinterMonthListByLat(lat) {
  lat = ee.Number(lat);
  return ee.List(ee.Algorithms.If(
    lat.gte(0),
    [11, 12, 1, 2, 3],
    [5, 6, 7, 8, 9]
  ));
}

function getIceRiskByLat(lat) {
  lat = ee.Number(lat);
  return ee.Number(ee.Algorithms.If(
    USE_LATITUDE_ICE_RISK,
    lat.abs().gte(ICE_RISK_LAT_THR),
    1
  ));
}

function imageAreaKm2(img, geom, scale, bandName) {
  img = ee.Image(img).select(bandName);

  var area = img.multiply(ee.Image.pixelArea()).reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: geom,
    scale: scale,
    bestEffort: true,
    tileScale: 16,
    maxPixels: 1e13
  }).get(bandName);

  return ee.Number(ee.Algorithms.If(area, area, 0)).divide(1e6);
}

function reduceBandSums(img, geom, scale) {
  img = ee.Image(img);

  return ee.Dictionary(img.reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: geom,
    scale: scale,
    bestEffort: true,
    tileScale: 16,
    maxPixels: 1e13
  }));
}


// ====================== 5. L7 SLC-off 条带修复 ======================
function repairL7SLCOff(refl, goodMaskNoFill, radsatMask) {
  refl = ee.Image(refl);

  var rawPositive = refl.select(['blue', 'green', 'red', 'nir', 'swir1'])
    .gt(0)
    .reduce(ee.Reducer.min());

  var fillBase = refl
    .updateMask(goodMaskNoFill)
    .updateMask(radsatMask)
    .updateMask(rawPositive);

  var fill1 = fillBase.focal_mean({
    radius: 1.5,
    units: 'pixels',
    kernelType: 'square',
    iterations: 1
  });

  var fill2 = fillBase.focal_mean({
    radius: 3,
    units: 'pixels',
    kernelType: 'square',
    iterations: 1
  });

  return fillBase.unmask(fill1).unmask(fill2);
}


// ====================== 6. 预处理：T1 + L7修复 + 冰雪风险控制 ======================
function prepImage(img, sensorName, winterMonthList, iceRisk) {
  img = ee.Image(img);
  winterMonthList = ee.List(winterMonthList);
  iceRisk = ee.Number(iceRisk);

  var qa = img.select('QA_PIXEL');
  var radsat = img.select('QA_RADSAT');

  var fill = qa.bitwiseAnd(1 << 0).neq(0);
  var dilatedCloud = qa.bitwiseAnd(1 << 1).neq(0);
  var cirrus = sensorName === 'L8'
    ? qa.bitwiseAnd(1 << 2).neq(0)
    : ee.Image(0);
  var cloud = qa.bitwiseAnd(1 << 3).neq(0);
  var cloudShadow = qa.bitwiseAnd(1 << 4).neq(0);
  var snowIceQA = qa.bitwiseAnd(1 << 5).neq(0);

  var badMask = fill
    .or(dilatedCloud)
    .or(cirrus)
    .or(cloud)
    .or(cloudShadow)
    .or(snowIceQA);

  var badNoFill = dilatedCloud
    .or(cirrus)
    .or(cloud)
    .or(cloudShadow)
    .or(snowIceQA);

  var radMask = radsat.eq(0);

  var bands = sensorName === 'L8'
    ? ['SR_B2', 'SR_B3', 'SR_B4', 'SR_B5', 'SR_B6', 'SR_B7']
    : ['SR_B1', 'SR_B2', 'SR_B3', 'SR_B4', 'SR_B5', 'SR_B7'];

  var refl = img.select(
      bands,
      ['blue', 'green', 'red', 'nir', 'swir1', 'swir2']
    )
    .multiply(0.0000275)
    .add(-0.2);

  var date = ee.Date(img.get('system:time_start'));
  var month = ee.Number(date.get('month'));

  // ---------- L7 SLC-off 修复 ----------
  var isAfterSLC = date.millis().gt(SLC_OFF_DATE.millis());

  var doRepair = (REPAIR_L7_SLC_OFF && sensorName === 'L7')
    ? isAfterSLC
    : ee.Number(0).eq(1);

  refl = ee.Image(ee.Algorithms.If(
    doRepair,
    repairL7SLCOff(refl, badNoFill.not(), radMask),
    refl
  ));

  // L7 修复后，baseMask 用 badNoFill，避免 fill 位把修复像元再次遮掉
  var baseMask = ee.Image(ee.Algorithms.If(
    doRepair,
    badNoFill.not(),
    badMask.not()
  ));

  // ---------- L8 可见光上限 ----------
  var extraMask = (sensorName === 'L8' && USE_L8_BRIGHT_MASK)
    ? refl.select('blue').lt(L8_BLUE_THR)
        .and(refl.select('green').lt(L8_GREEN_THR))
        .and(refl.select('red').lt(L8_RED_THR))
    : ee.Image.constant(1);

  // ---------- 去雪冰：基础过滤 + 冰雪风险湖泊冬季强化 ----------
  var ndsi = refl.normalizedDifference(['green', 'swir1']);

  var snowMask = ndsi.gt(0.42)
    .and(refl.select('green').gt(0.20))
    .and(refl.select('nir').gt(0.10));

  var brightIceMask = refl.select('green').gt(0.30)
    .or(refl.select('red').gt(0.30));

  var baseSnowIceMask = snowMask.or(snowIceQA);

  var strongIceSnowMask = snowMask
    .or(brightIceMask)
    .or(snowIceQA)
    .or(ndsi.gt(0.35));

  var isWinter = winterMonthList.contains(month);

  var iceSnowMask = ee.Image(ee.Algorithms.If(
    USE_SNOW_ICE_MASK,
    ee.Algorithms.If(
      iceRisk.eq(1),
      ee.Algorithms.If(
        isWinter,
        strongIceSnowMask,
        baseSnowIceMask
      ),
      baseSnowIceMask
    ),
    ee.Image(0)
  ));

  var finalMask = baseMask
    .and(radMask)
    .and(extraMask)
    .and(iceSnowMask.not());

  if (USE_POSITIVE_MASK) {
    var positiveMask = refl.select(['blue', 'green', 'red', 'nir', 'swir1'])
      .gt(0)
      .reduce(ee.Reducer.min());

    finalMask = finalMask.and(positiveMask);
  }

  var valid = ee.Image.constant(1)
    .updateMask(finalMask)
    .rename('valid');

  return refl.updateMask(finalMask)
    .addBands(valid)
    .set('SENSOR', sensorName)
    .set('date_str', date.format('YYYY-MM-dd'))
    .set('month', month)
    .set('year', date.get('year'))
    .set('slc_repaired', doRepair)
    .copyProperties(img, ['system:time_start']);
}


// ====================== 7. 年度影像集合 ======================
function getAnnualMappedCollection(geom, year, winterMonthList, iceRisk) {
  year = Number(year);

  var start = ee.Date.fromYMD(year, 1, 1);
  var end = start.advance(1, 'year');

  // 保留旧逻辑：L5 跳过 2000 和 2009；2000–2012 保留 L7
  var l5Col = (year <= 2012 && year !== 2000 && year !== 2009)
    ? L5.filterBounds(geom)
        .filterDate(start, end)
        .map(function (img) {
          return prepImage(img, 'L5', winterMonthList, iceRisk);
        })
    : ee.ImageCollection([]);

  var l7Col = (year <= 2012)
    ? L7.filterBounds(geom)
        .filterDate(start, end)
        .map(function (img) {
          return prepImage(img, 'L7', winterMonthList, iceRisk);
        })
    : ee.ImageCollection([]);

  var l8Col = (year >= 2013)
    ? L8.filterBounds(geom)
        .filterDate(start, end)
        .map(function (img) {
          return prepImage(img, 'L8', winterMonthList, iceRisk);
        })
    : ee.ImageCollection([]);

  return ee.ImageCollection(l5Col).merge(l7Col).merge(l8Col);
}


// ====================== 8. B 方案：Hou strict + FAI ======================
function bloomdetect(im) {
  im = ee.Image(im);

  var R = im.select('red');
  var G = im.select('green');
  var B = im.select('blue');
  var N = im.select('nir');
  var S = im.select('swir1');
  var valid = im.select('valid');

  var denom = R.multiply(3.7689)
    .add(G.multiply(6.3989))
    .add(B.multiply(6.7837))
    .max(ee.Image.constant(0.0001));

  var X = R.multiply(2.7689)
    .add(G.multiply(1.7517))
    .add(B.multiply(1.1302))
    .divide(denom);

  var Y = R
    .add(G.multiply(4.5907))
    .add(B.multiply(0.0601))
    .divide(denom);

  var poly = X.pow(3).multiply(223.201344)
    .subtract(X.pow(2).multiply(189.247165))
    .add(X.multiply(51.708314))
    .subtract(4.108605);

  var Ydiff = Y.subtract(poly);

  var rsmask = G.lt(0.5)
    .and(R.lt(0.5))
    .and(B.lt(0.5));

  var rafai = R.subtract(G.multiply(0.5)).subtract(N.multiply(0.5));
  var rgDiff = R.subtract(G);

  var FAI = N.subtract(R).subtract(S.subtract(R).multiply(0.5));

  var bloomCond = Ydiff.gte(0)
    .and(rafai.lt(0))
    .and(rgDiff.lt(0))
    .and(G.gt(0.02))
    .and(rsmask)
    .and(FAI.gt(FAI_THR))
    .and(valid.eq(1))
    .and(getPhysMask());

  return bloomCond.rename('bloom').toByte()
    .copyProperties(im, ['system:time_start', 'date_str', 'month', 'year', 'SENSOR', 'slc_repaired']);
}

function validObsImage(im) {
  im = ee.Image(im);

  return im.select('valid')
    .updateMask(getPhysMask())
    .rename('validObs')
    .copyProperties(im, ['system:time_start', 'date_str', 'month', 'year', 'SENSOR', 'slc_repaired']);
}


// ====================== 9. 同日拼接 ======================
function buildDailyCollectionNonEmpty(mCol) {
  var dateList = ee.List(mCol.aggregate_array('date_str'))
    .distinct()
    .sort();

  var dailyList = dateList.map(function (ds) {
    ds = ee.String(ds);

    var dayCol = mCol.filter(ee.Filter.eq('date_str', ds));

    var dailyValid = ee.ImageCollection(dayCol.map(function (im) {
      return ee.Image(validObsImage(im)).unmask(0);
    })).max().rename('validObs');

    var dailyBloom = ee.ImageCollection(dayCol.map(function (im) {
      return ee.Image(bloomdetect(im)).unmask(0);
    })).max()
      .updateMask(dailyValid.gt(0))
      .rename('bloom');

    return ee.Image.cat([dailyBloom, dailyValid])
      .set('date_str', ds)
      .set('system:time_start', ee.Date.parse('YYYY-MM-dd', ds).millis());
  });

  return ee.ImageCollection.fromImages(dailyList);
}


// ====================== 10. 月度摘要 ======================
function monthlySummaryDict(mCol, geom, scale) {
  var sceneCount = mCol.size();

  return ee.Dictionary(ee.Algorithms.If(
    sceneCount.gt(0),
    monthlySummaryDictNonEmpty(mCol, geom, scale),
    ee.Dictionary({
      scene_count: 0,
      day_count: 0,
      best_date: 'NA',
      max_area_km2: 0,
      bloom_pixel_obs: 0,
      valid_pixel_obs: 0
    })
  ));
}

function monthlySummaryDictNonEmpty(mCol, geom, scale) {
  var dailyCol = buildDailyCollectionNonEmpty(mCol);

  var dailyAreaCol = dailyCol.map(function (img) {
    img = ee.Image(img);
    var areaKm2 = imageAreaKm2(
      img.select('bloom'),
      geom,
      scale,
      'bloom'
    );
    return img.set('area_km2', areaKm2);
  });

  var hasAnyDaily = dailyAreaCol.size().gt(0);

  var best = ee.Image(ee.Algorithms.If(
    hasAnyDaily,
    dailyAreaCol.sort('area_km2', false).first(),
    ee.Image.constant(0)
      .rename('bloom')
      .set('date_str', 'NA')
      .set('area_km2', 0)
  ));

  var monthlySumImg = ee.ImageCollection(dailyCol.map(function (img) {
    img = ee.Image(img);
    return img.select(['bloom', 'validObs']).unmask(0);
  })).sum();

  var sums = reduceBandSums(monthlySumImg, geom, scale);

  var bloomObs = ee.Number(ee.Algorithms.If(
    sums.get('bloom'),
    sums.get('bloom'),
    0
  ));

  var validObs = ee.Number(ee.Algorithms.If(
    sums.get('validObs'),
    sums.get('validObs'),
    0
  ));

  return ee.Dictionary({
    scene_count: mCol.size(),
    day_count: dailyCol.size(),
    best_date: ee.String(ee.Algorithms.If(
      hasAnyDaily,
      best.get('date_str'),
      'NA'
    )),
    max_area_km2: ee.Number(ee.Algorithms.If(
      hasAnyDaily,
      best.get('area_km2'),
      0
    )),
    bloom_pixel_obs: bloomObs,
    valid_pixel_obs: validObs
  });
}


// ====================== 11. 年度 BO：侯雪娇像元频率思想 + 最低有效观测限制 ======================
function annualBODict(aCol, geom, scale) {
  var sceneCount = aCol.size();

  return ee.Dictionary(ee.Algorithms.If(
    sceneCount.gt(0),
    annualBODictNonEmpty(aCol, geom, scale),
    ee.Dictionary({
      Annual_BO_mean: 0,
      Annual_BO_mean_pct: 0,
      Annual_BO_sum_ratio: 0,
      Annual_BO_sum_ratio_pct: 0,
      Nbloom_sum: 0,
      Nvalid_sum: 0,
      valid_pixel_count_for_bo: 0
    })
  ));
}

function annualBODictNonEmpty(aCol, geom, scale) {
  var dailyCol = buildDailyCollectionNonEmpty(aCol);

  var sumImg = ee.ImageCollection(dailyCol.map(function (img) {
    img = ee.Image(img);
    return img.select(['bloom', 'validObs']).unmask(0);
  })).sum();

  var nbloom = sumImg.select('bloom').rename('Nbloom');
  var nvalid = sumImg.select('validObs').rename('Nvalid');

  var validPixelMaskForBO = nvalid.gte(MIN_VALID_DAYS_FOR_BO);

  // 主 BO：像元层面 Nbloom/Nvalid 后求湖泊平均
  var boPixel = nbloom.divide(nvalid)
    .updateMask(validPixelMaskForBO)
    .rename('BO_pixel');

  var boMean = boPixel.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: geom,
    scale: scale,
    bestEffort: true,
    tileScale: 16,
    maxPixels: 1e13
  }).get('BO_pixel');

  var boMeanNum = ee.Number(ee.Algorithms.If(boMean, boMean, 0));

  // 诊断 BO：sum(Nbloom)/sum(Nvalid)，但只统计 Nvalid 达标像元
  var sumImgMasked = ee.Image.cat([
    nbloom.updateMask(validPixelMaskForBO).rename('bloom'),
    nvalid.updateMask(validPixelMaskForBO).rename('validObs')
  ]);

  var sums = reduceBandSums(sumImgMasked, geom, scale);

  var nbloomSum = ee.Number(ee.Algorithms.If(
    sums.get('bloom'),
    sums.get('bloom'),
    0
  ));

  var nvalidSum = ee.Number(ee.Algorithms.If(
    sums.get('validObs'),
    sums.get('validObs'),
    0
  ));

  var boSumRatio = ee.Number(ee.Algorithms.If(
    nvalidSum.gt(0),
    nbloomSum.divide(nvalidSum),
    0
  ));

  var validPixelArea = ee.Image.constant(1)
    .updateMask(validPixelMaskForBO)
    .rename('valid_pixel_count_for_bo')
    .reduceRegion({
      reducer: ee.Reducer.sum(),
      geometry: geom,
      scale: scale,
      bestEffort: true,
      tileScale: 16,
      maxPixels: 1e13
    })
    .get('valid_pixel_count_for_bo');

  return ee.Dictionary({
    Annual_BO_mean: boMeanNum,
    Annual_BO_mean_pct: boMeanNum.multiply(100),

    Annual_BO_sum_ratio: boSumRatio,
    Annual_BO_sum_ratio_pct: boSumRatio.multiply(100),

    Nbloom_sum: nbloomSum,
    Nvalid_sum: nvalidSum,

    valid_pixel_count_for_bo: ee.Number(ee.Algorithms.If(
      validPixelArea,
      validPixelArea,
      0
    ))
  });
}


// ====================== 12. 月最大日图 ======================
function monthlyMaxImageAndInfo(mCol, geom, scale) {
  var sceneCount = mCol.size();

  return ee.Dictionary(ee.Algorithms.If(
    sceneCount.gt(0),
    monthlyMaxImageAndInfoNonEmpty(mCol, geom, scale),
    ee.Dictionary({
      image: ee.Image.constant(0).rename('bloom').selfMask(),
      scene_count: 0,
      day_count: 0,
      best_date: 'NA',
      max_area_km2: 0
    })
  ));
}

function monthlyMaxImageAndInfoNonEmpty(mCol, geom, scale) {
  var dailyCol = buildDailyCollectionNonEmpty(mCol);

  var dailyAreaCol = dailyCol.map(function (img) {
    img = ee.Image(img);
    var areaKm2 = imageAreaKm2(img.select('bloom'), geom, scale, 'bloom');
    return img.set('area_km2', areaKm2);
  });

  var best = ee.Image(dailyAreaCol.sort('area_km2', false).first());

  return ee.Dictionary({
    image: best.select('bloom'),
    scene_count: mCol.size(),
    day_count: dailyCol.size(),
    best_date: best.get('date_str'),
    max_area_km2: best.get('area_km2')
  });
}


