/**************************************************
 * UI 核查版：B 固定版 + 冰雪风险控制 + BO 修正版
 *
 * B = Hou strict + FAI
 *
 * 预处理：
 * 1. Landsat C02 L2 T1 only
 * 2. L7 SLC-off 修复
 * 3. QA_PIXEL 去 fill、dilated cloud、cirrus、cloud、cloud shadow、snow/ice
 * 4. QA_RADSAT 去饱和
 * 5. L8 保留 blue < 0.12, green < 0.15, red < 0.15
 * 6. 加强去雪冰，但只对潜在冰雪风险湖泊启用冬季强化
 *    - |lat| >= 35°：启用冬季强化
 *    - |lat| < 35°：只用基础 snowMask + snowIceQA
 * 7. 不使用 adjacency
 * 8. 不使用 aerosol
 * 9. 不使用 haze mask
 * 10. 不使用 positiveMask
 *
 * MBE：
 * 每景识别 -> 同日拼接 -> 每日面积 -> 月最大日面积 -> 年最大
 *
 * BO：
 * 主 BO：Annual_BO_mean_pct = mean(pixel-wise Nbloom/Nvalid), Nvalid >= MIN_VALID_DAYS_FOR_BO
 * 诊断 BO：Annual_BO_sum_ratio_pct = sum(Nbloom)/sum(Nvalid), 同样限制 Nvalid
 **************************************************/

// ====================== 0. 参数设置 ======================
var lakes = table;
var lakeNameField = 'Lake_name';

var YEAR_START = 2000;
var YEAR_END = 2024;

// 核查建议 500；如果 UI 太慢，可临时改 1000
var STAT_SCALE = 500;
var GEOM_SIMPLIFY = 600;

// 水体掩膜
var WATER_OCC_THR = 90;

// B 方案固定：Hou strict + FAI
var FAI_THR = 0.003;

// BO 最低有效观测次数。
// 如果一年内某像元 Nvalid < 3，不参与年度 BO 平均。
var MIN_VALID_DAYS_FOR_BO = 3;

// 冰雪风险纬度阈值。
// |lat| >= 35° 才启用冬季强化去冰雪。
// 非洲低纬湖泊不会触发强冰雪过滤。
var USE_LATITUDE_ICE_RISK = true;
var ICE_RISK_LAT_THR = 35;

// L7 SLC-off 修复
var REPAIR_L7_SLC_OFF = true;
var SLC_OFF_DATE = ee.Date('2003-05-31');

// L8 可见光上限
var USE_L8_BRIGHT_MASK = true;
var L8_BLUE_THR = 0.12;
var L8_GREEN_THR = 0.15;
var L8_RED_THR = 0.15;

// 去雪冰
var USE_SNOW_ICE_MASK = true;

// 明确关闭这些项
var USE_POSITIVE_MASK = false;
var USE_L8_AEROSOL_MASK = false;
var USE_VIS_HAZE_MASK = false;


