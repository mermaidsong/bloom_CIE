// ====================== 14. 时间序列 ======================
function drawTimeSeries() {
  if (!beginJob('时间序列')) return;

  var name = lakeSelect.getValue();

  if (!name) {
    print('❌ 请先选择湖泊');
    endJob();
    return;
  }

  var mapGeom = getLakeGeomForMap(name);
  var statGeom = getLakeGeomForStats(name);

  var lat = getLakeCentroidLat(name);
  var winterMonthList = getWinterMonthListByLat(lat);
  var iceRisk = getIceRiskByLat(lat);

  print('==============================');
  print('湖泊：', name);
  print('年份：', YEAR_START + '–' + YEAR_END);
  print('版本：B Hou strict + FAI');
  print('STAT_SCALE：', STAT_SCALE);
  print('GEOM_SIMPLIFY：', GEOM_SIMPLIFY);
  print('FAI 阈值：', FAI_THR);
  print('Adjacency：false');
  print('T1 only：true');
  print('L7 SLC repair：', REPAIR_L7_SLC_OFF);
  print('L8 blue/green/red：', L8_BLUE_THR, L8_GREEN_THR, L8_RED_THR);
  print('湖泊质心纬度：', lat);
  print('冬季月份：', winterMonthList);
  print('iceRisk | abs(lat) >= ' + ICE_RISK_LAT_THR + '：', iceRisk);
  print('BO_min_valid_days：', MIN_VALID_DAYS_FOR_BO);
  print('MBE：月最大日面积，再取年最大');
  print('BO_mean：mean(pixel-wise Nbloom/Nvalid), Nvalid >= MIN_VALID');
  print('BO_sum_ratio：sum(Nbloom)/sum(Nvalid), Nvalid >= MIN_VALID');
  print('==============================');

  Map.centerObject(mapGeom, 5);
  Map.layers().reset();

  Map.addLayer(mapGeom, {color: 'yellow'}, name + ' geometry');
  Map.addLayer(
    getStrictJRCMask().selfMask().clip(mapGeom),
    {palette: ['0000ff']},
    'JRC occurrence >= 90'
  );

  chartPanel.clear();
  chartPanel.add(ui.Label('正在计算，请看 Console 进度。'));
  runBtn.setDisabled(true);

  var years = [];
  for (var y = YEAR_START; y <= YEAR_END; y++) {
    years.push(y);
  }

  var xData = [];
  var peakData = [];
  var boMeanData = [];
  var boSumData = [];

  var yi = 0;

  function finishSeries() {
    runBtn.setDisabled(false);
    renderCharts(name, xData, peakData, boMeanData, boSumData);
    print('✅ 时间序列完成');
    endJob();
  }

  function processYear() {
    if (yi >= years.length) {
      finishSeries();
      return;
    }

    var year = years[yi];
    var col = getAnnualMappedCollection(
      mapGeom,
      year,
      winterMonthList,
      iceRisk
    );

    var month = 1;
    var yearPeak = null;
    var peakMonth = null;
    var peakDate = 'NA';
    var monthVals = [];

    function finishYear() {
      var boDict = annualBODict(
        col,
        statGeom,
        STAT_SCALE
      );

      boDict.evaluate(function (bo, err) {
        var boMeanPct = 0;
        var boSumPct = 0;
        var nbloomSum = 0;
        var nvalidSum = 0;
        var validPixelCount = 0;

        if (err || !bo) {
          print('❌ ' + year + ' 年 BO 计算失败：', err);
        } else {
          boMeanPct = Number(bo.Annual_BO_mean_pct) || 0;
          boSumPct = Number(bo.Annual_BO_sum_ratio_pct) || 0;
          nbloomSum = Number(bo.Nbloom_sum) || 0;
          nvalidSum = Number(bo.Nvalid_sum) || 0;
          validPixelCount = Number(bo.valid_pixel_count_for_bo) || 0;
        }

        xData.push(year);
        peakData.push(yearPeak === null ? 0 : yearPeak);
        boMeanData.push(boMeanPct);
        boSumData.push(boSumPct);

        print(
          year +
          ' | Peak=' + (yearPeak === null ? 'NA' : yearPeak.toFixed(2)) +
          ' km² | peak_month=' + peakMonth +
          ' | peak_date=' + peakDate +
          ' | BO_mean=' + boMeanPct.toFixed(4) +
          '% | BO_sum_ratio=' + boSumPct.toFixed(4) +
          '% | Nbloom_sum=' + nbloomSum.toFixed(2) +
          ' | Nvalid_sum=' + nvalidSum.toFixed(2) +
          ' | validPixelCountForBO=' + validPixelCount.toFixed(2) +
          ' | monthVals=' + JSON.stringify(monthVals)
        );

        yi++;
        processYear();
      });
    }

    function processMonth() {
      if (month > 12) {
        finishYear();
        return;
      }

      var thisMonth = month;

      var mCol = col.filter(
        ee.Filter.calendarRange(thisMonth, thisMonth, 'month')
      );

      var s = monthlySummaryDict(
        mCol,
        statGeom,
        STAT_SCALE
      ).set('month', thisMonth);

      s.evaluate(function (d, err) {
        if (err || !d) {
          print('❌ ' + year + ' 年第 ' + thisMonth + ' 月失败：', err);
          monthVals.push(null);
        } else {
          var area = Number(d.max_area_km2);
          monthVals.push(isFinite(area) ? area : null);

          if (isFinite(area) && (yearPeak === null || area > yearPeak)) {
            yearPeak = area;
            peakMonth = thisMonth;
            peakDate = d.best_date;
          }
        }

        month++;
        processMonth();
      });
    }

    processMonth();
  }

  processYear();
}


// ====================== 15. 年份逐月检查 ======================
function checkMonthlyForYear(year) {
  if (!beginJob('年份逐月检查 ' + year)) return;

  if (!year || isNaN(year) || year < YEAR_START || year > YEAR_END) {
    print('❌ 年份无效。本代码年份范围为 ' + YEAR_START + '–' + YEAR_END);
    endJob();
    return;
  }

  var name = lakeSelect.getValue();
  var mapGeom = getLakeGeomForMap(name);
  var statGeom = getLakeGeomForStats(name);

  var lat = getLakeCentroidLat(name);
  var winterMonthList = getWinterMonthListByLat(lat);
  var iceRisk = getIceRiskByLat(lat);

  var col = getAnnualMappedCollection(
    mapGeom,
    year,
    winterMonthList,
    iceRisk
  );

  print('==============================');
  print('检查湖泊：', name);
  print('年份：', year);
  print('总影像数 raw：', col.size());
  print('湖泊质心纬度：', lat);
  print('冬季月份：', winterMonthList);
  print('iceRisk：', iceRisk);
  print('==============================');

  var month = 1;

  function finishCheck() {
    endJob();
  }

  function processMonth() {
    if (month > 12) {
      finishCheck();
      return;
    }

    var thisMonth = month;

    var mCol = col.filter(
      ee.Filter.calendarRange(thisMonth, thisMonth, 'month')
    );

    var s = monthlySummaryDict(
      mCol,
      statGeom,
      STAT_SCALE
    ).set('month', thisMonth);

    s.evaluate(function (d, err) {
      if (err || !d) {
        print('❌ 第 ' + thisMonth + ' 月失败：', err);
      } else {
        var boMonth = 0;

        if (Number(d.valid_pixel_obs) > 0) {
          boMonth = Number(d.bloom_pixel_obs) / Number(d.valid_pixel_obs) * 100;
        }

        print(
          '第 ' + d.month +
          ' 月 | scene=' + d.scene_count +
          ' | day=' + d.day_count +
          ' | best_date=' + d.best_date +
          ' | MBE=' + (Number(d.max_area_km2) || 0).toFixed(2) + ' km²' +
          ' | BO_month_sum_ratio=' + boMonth.toFixed(4) + '%' +
          ' | bloom_obs=' + d.bloom_pixel_obs +
          ' | valid_obs=' + d.valid_pixel_obs
        );
      }

      month++;
      processMonth();
    });
  }

  processMonth();
}


