function beginJob(jobName) {
  if (ACTIVE_JOB !== null) {
    print('⚠️ 当前仍在运行：' + ACTIVE_JOB + '，请等待结束后再启动新任务。');
    return false;
  }
  ACTIVE_JOB = jobName;
  print('▶️ 开始任务：' + jobName);
  return true;
}

function endJob() {
  if (ACTIVE_JOB !== null) {
    print('✅ 任务结束：' + ACTIVE_JOB);
  }
  ACTIVE_JOB = null;
}


